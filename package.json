{
  "name": "@devsuvam/odialang",
  "version": "1.0.3",
  "description": "A file-based, CLI-driven programming language with Odia (Oriya) keywords that compiles to JavaScript",
  "main": "dist/cli/index.js",
  "bin": {
    "odia": "dist/cli/index.js",
    "odialang-setup": "scripts/setup-syntax.js"
  },
  "files": [
    "dist/",
    "scripts/",
    "syntax-highlighting/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "clean": "rm -rf dist",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "odia",
    "programming-language",
    "cli",
    "compiler",
    "javascript",
    "transpiler",
    "regional-language",
    "indian-languages",
    "syntax-highlighting",
    "vscode-extension",
    "monaco-editor"
  ],
  "author": "Jyotishankar Patra <jyotipatra.subham@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jyotishankar04/odialang.git"
  },
  "bugs": {
    "url": "https://github.com/jyotishankar04/odialang/issues"
  },
  "homepage": "https://github.com/jyotishankar04/odialang#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}

{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Odialang",
  "scopeName": "source.odia",
  "fileTypes": [".odia"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.odia",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.odia",
          "match": "\\b(dhara|dekha|jadi|tahale|nahele|jebe|karya|fera|sesa|aarambha|ru|kar)\\b"
        },
        {
          "name": "constant.language.boolean.odia",
          "match": "\\b(sata|micha)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.odia",
          "begin": "\\b(karya)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.odia"
            },
            "2": {
              "name": "entity.name.function.odia"
            }
          },
          "end": "\\)",
          "patterns": [
            {
              "name": "variable.parameter.odia",
              "match": "[a-zA-Z_][a-zA-Z0-9_]*"
            },
            {
              "name": "punctuation.separator.parameter.odia",
              "match": ","
            }
          ]
        },
        {
          "name": "entity.name.function.odia",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.odia",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.odia",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.odia",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.odia",
          "match": "(\\+|-|\\*|/)"
        },
        {
          "name": "keyword.operator.comparison.odia",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.odia",
          "match": "="
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.odia",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
